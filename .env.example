OPENAI_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
LLM_MODEL=gpt-4o-mini
REPORT_DIR=reports
LOG_DIR=logs

# Walk-forward robust optimization (MVP local storage — no external DB required)
# OPTIMIZATION_REPORT_DIR=reports/  # optional override; defaults to REPORT_DIR
# OPTIMIZATION_DEFAULT_FEE_PCT=0.05   # one-way fee in percent
# OPTIMIZATION_DEFAULT_SLIPPAGE_PCT=0.05  # one-way slippage in percent

# PostgreSQL source of truth (004 US1)
DATABASE_URL=postgresql+psycopg://finsight:finsight@localhost:5432/finsight
# Test database — when unset, PostgreSQL tests are skipped
TEST_DATABASE_URL=postgresql+psycopg://finsight:finsight@localhost:5432/finsight_test
